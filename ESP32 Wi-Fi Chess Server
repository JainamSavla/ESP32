bool inBounds(int r, int c) {
	return r >= 0 && r < 8 && c >= 0 && c < 8;
}

bool isUpperPiece(char p) {
	return p >= 'A' && p <= 'Z';
}

bool isLowerPiece(char p) {
	return p >= 'a' && p <= 'z';
}

bool isEmptySquare(char p) {
	return p == '.';
}

bool isWhitePiece(char p) {
	return isUpperPiece(p);
}

bool isBlackPiece(char p) {
	return isLowerPiece(p);
}

bool isOwnPiece(char p, bool white) {
	if (isEmptySquare(p)) return false;
	return white ? isWhitePiece(p) : isBlackPiece(p);
}

bool isEnemyPiece(char p, bool white) {
	if (isEmptySquare(p)) return false;
	return white ? isBlackPiece(p) : isWhitePiece(p);
}

String squareName(int row, int col) {
	char file = 'a' + col;
	char rank = '8' - row;
	String out;
	out += file;
	out += rank;
	return out;
}

bool parseSquare(const String& s, int& row, int& col) {
	if (s.length() != 2) return false;
	char file = tolower(s[0]);
	char rank = s[1];

	if (file < 'a' || file > 'h') return false;
	if (rank < '1' || rank > '8') return false;

	col = file - 'a';
	row = 8 - (rank - '0');
	return true;
}

bool pathClearStraight(int r1, int c1, int r2, int c2) {
	int dr = (r2 > r1) ? 1 : (r2 < r1 ? -1 : 0);
	int dc = (c2 > c1) ? 1 : (c2 < c1 ? -1 : 0);

	int r = r1 + dr;
	int c = c1 + dc;
	while (r != r2 || c != c2) {
		if (!isEmptySquare(board[r][c])) return false;
		r += dr;
		c += dc;
	}
	return true;
}

bool validatePawnMove(int fr, int fc, int tr, int tc, bool white) {
	int dir = white ? -1 : 1;
	int startRow = white ? 6 : 1;

	if (fc == tc) {
		if (tr == fr + dir && isEmptySquare(board[tr][tc])) return true;
		if (fr == startRow && tr == fr + 2 * dir && isEmptySquare(board[fr + dir][fc]) && isEmptySquare(board[tr][tc])) {
			return true;
		}
		return false;
	}

	if (abs(tc - fc) == 1 && tr == fr + dir && isEnemyPiece(board[tr][tc], white)) {
		return true;
	}

	return false;
}

bool validateKnightMove(int fr, int fc, int tr, int tc) {
	int dr = abs(tr - fr);
	int dc = abs(tc - fc);
	return (dr == 2 && dc == 1) || (dr == 1 && dc == 2);
}

bool validateBishopMove(int fr, int fc, int tr, int tc) {
	int dr = abs(tr - fr);
	int dc = abs(tc - fc);
	if (dr != dc) return false;
	return pathClearStraight(fr, fc, tr, tc);
}

bool validateRookMove(int fr, int fc, int tr, int tc) {
	if (fr != tr && fc != tc) return false;
	return pathClearStraight(fr, fc, tr, tc);
}

bool validateQueenMove(int fr, int fc, int tr, int tc) {
	int dr = abs(tr - fr);
	int dc = abs(tc - fc);
	if (dr == dc) return pathClearStraight(fr, fc, tr, tc);
	if (fr == tr || fc == tc) return pathClearStraight(fr, fc, tr, tc);
	return false;
}

bool validateKingMove(int fr, int fc, int tr, int tc) {
	int dr = abs(tr - fr);
	int dc = abs(tc - fc);
	return dr <= 1 && dc <= 1;
}

bool validateMove(int fr, int fc, int tr, int tc, String& errorOut) {
	if (!inBounds(fr, fc) || !inBounds(tr, tc)) {
		errorOut = "Out of bounds";
		return false;
	}

	if (fr == tr && fc == tc) {
		errorOut = "Source and destination are same";
		return false;
	}

	char piece = board[fr][fc];
	if (isEmptySquare(piece)) {
		errorOut = "No piece at source";
		return false;
	}

	bool movingWhite = isWhitePiece(piece);
	if (movingWhite != whiteTurn) {
		errorOut = "Not your turn";
		return false;
	}

	char target = board[tr][tc];
	if (isOwnPiece(target, movingWhite)) {
		errorOut = "Cannot capture own piece";
		return false;
	}

	char lower = tolower(piece);
	bool valid = false;

	if (lower == 'p') valid = validatePawnMove(fr, fc, tr, tc, movingWhite);
	else if (lower == 'n') valid = validateKnightMove(fr, fc, tr, tc);
	else if (lower == 'b') valid = validateBishopMove(fr, fc, tr, tc);
	else if (lower == 'r') valid = validateRookMove(fr, fc, tr, tc);
	else if (lower == 'q') valid = validateQueenMove(fr, fc, tr, tc);
	else if (lower == 'k') valid = validateKingMove(fr, fc, tr, tc);

	if (!valid) {
		errorOut = "Illegal move for selected piece";
		return false;
	}

	return true;
}

bool hasKing(bool white) {
	char k = white ? 'K' : 'k';
	for (int r = 0; r < 8; r++) {
		for (int c = 0; c < 8; c++) {
			if (board[r][c] == k) return true;
		}
	}
	return false;
}

void pushMoveHistory(const String& entry) {
	if (moveCount < 256) {
		moveHistory[moveCount++] = entry;
		return;
	}

	for (int i = 1; i < 256; i++) {
		moveHistory[i - 1] = moveHistory[i];
	}
	moveHistory[255] = entry;
}

void resetBoard() {
	const char* initial[8] = {
		"rnbqkbnr",
		"pppppppp",
		"........",
		"........",
		"........",
		"........",
		"PPPPPPPP",
		"RNBQKBNR"
	};

	for (int r = 0; r < 8; r++) {
		for (int c = 0; c < 8; c++) {
			board[r][c] = initial[r][c];
		}
	}

	whiteTurn = true;
	gameOver = false;
	winner = "";
	moveCount = 0;
}

String boardToJson() {
	String json;
	json.reserve(1800);

	json += "{";
	json += "\"board\":[";
	for (int r = 0; r < 8; r++) {
		json += "\"";
		for (int c = 0; c < 8; c++) {
			json += board[r][c];
		}
		json += "\"";
		if (r < 7) json += ",";
	}
	json += "],";

	json += "\"whiteTurn\":";
	json += whiteTurn ? "true" : "false";
	json += ",";

	json += "\"gameOver\":";
	json += gameOver ? "true" : "false";
	json += ",";

	json += "\"winner\":\"";
	json += winner;
	json += "\",";

	json += "\"history\":[";
	for (int i = 0; i < moveCount; i++) {
		String e = moveHistory[i];
		e.replace("\\", "\\\\");
		e.replace("\"", "\\\"");
		json += "\"";
		json += e;
		json += "\"";
		if (i < moveCount - 1) json += ",";
	}
	json += "]";

	json += "}";
	return json;
}

void handleRoot() {
	server.send_P(200, "text/html", INDEX_HTML);
}

void handleState() {
	server.send(200, "application/json", boardToJson());
}

void handleMove() {
	if (gameOver) {
		server.send(400, "application/json", "{\"ok\":false,\"error\":\"Game over. Reset to play again\"}");
		return;
	}

	if (!server.hasArg("from") || !server.hasArg("to")) {
		server.send(400, "application/json", "{\"ok\":false,\"error\":\"Missing from/to parameters\"}");
		return;
	}

	String from = server.arg("from");
	String to = server.arg("to");

	int fr, fc, tr, tc;
	if (!parseSquare(from, fr, fc) || !parseSquare(to, tr, tc)) {
		server.send(400, "application/json", "{\"ok\":false,\"error\":\"Invalid square format\"}");
		return;
	}

	String err;
	if (!validateMove(fr, fc, tr, tc, err)) {
		String resp = "{\"ok\":false,\"error\":\"" + err + "\"}";
		server.send(400, "application/json", resp);
		return;
	}

	char moving = board[fr][fc];
	char captured = board[tr][tc];
	board[tr][tc] = moving;
	board[fr][fc] = '.';

	// Auto-promote pawns to queen to keep logic compact.
	if (moving == 'P' && tr == 0) board[tr][tc] = 'Q';
	if (moving == 'p' && tr == 7) board[tr][tc] = 'q';

	String moveText = String(whiteTurn ? "W: " : "B: ") + from + "->" + to;
	if (!isEmptySquare(captured)) {
		moveText += " x";
		moveText += captured;
	}
	pushMoveHistory(moveText);

	if (!hasKing(true)) {
		gameOver = true;
		winner = "Black";
		pushMoveHistory("Black wins (white king captured)");
	} else if (!hasKing(false)) {
		gameOver = true;
		winner = "White";
		pushMoveHistory("White wins (black king captured)");
	} else {
		whiteTurn = !whiteTurn;
	}

	server.send(200, "application/json", "{\"ok\":true}");
}

void handleReset() {
	resetBoard();
	server.send(200, "application/json", "{\"ok\":true}");
}

void setup() {
	Serial.begin(115200);
	delay(150);

	resetBoard();

	WiFi.mode(WIFI_AP);
	bool ok = WiFi.softAP(AP_SSID, AP_PASSWORD);

	Serial.println();
	Serial.println("===== ESP32 CHESS AP =====");
	Serial.printf("SoftAP start: %s\n", ok ? "OK" : "FAILED");
	Serial.printf("SSID: %s\n", AP_SSID);
	Serial.printf("PASS: %s\n", AP_PASSWORD);
	Serial.print("IP: ");
	Serial.println(WiFi.softAPIP());

	server.on("/", HTTP_GET, handleRoot);
	server.on("/state", HTTP_GET, handleState);
	server.on("/move", HTTP_GET, handleMove);
	server.on("/reset", HTTP_GET, handleReset);
	server.onNotFound([]() {
		server.send(404, "text/plain", "Not found");
	});

	server.begin();
	Serial.println("HTTP server started on port 80");
}

void loop() {
	server.handleClient();
}
