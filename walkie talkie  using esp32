// EXP1. Red-Black  - Tree Insertions
#include <stdio.h>
#include <stdlib.h>

typedef struct N {
    int v, c;
    struct N *p;
    struct N *k[2];
} N;

N *root = NULL;

N* newN(int v) {
    N *n = calloc(1, sizeof(N));
    n->v = v;
    n->c = 1;
    return n;
}

void rot(N *x, int d) {
    N *y = x->k[!d];

    x->k[!d] = y->k[d];
    if (y->k[d]) {
        y->k[d]->p = x;
    }

    y->p = x->p;

    if (!x->p) {
        root = y;
    } else {
        x->p->k[x->p->k[1] == x] = y;
    }

    y->k[d] = x;
    x->p = y;
}

void fix(N *z) {
    while (z->p && z->p->c) {
        int d = (z->p == z->p->p->k[1]);
        N *u = z->p->p->k[!d];

        if (u && u->c) {
            z->p->c = 0;
            u->c = 0;
            z->p->p->c = 1;
            z = z->p->p;
        } else {
            if (z == z->p->k[!d]) {
                z = z->p;
                rot(z, d);
            }

            z->p->c = 0;
            z->p->p->c = 1;
            rot(z->p->p, !d);
        }
    }
    root->c = 0;
}

void insert(int v) {
    N *z = newN(v);
    N *y = NULL;
    N *x = root;

    while (x) {
        y = x;
        x = x->k[v > x->v];
    }

    z->p = y;

    if (!y) {
        root = z;
    } else {
        y->k[v > y->v] = z;
    }

    fix(z);
}

void printLevelOrder() {
    if (!root) return;

    N *q[100];
    int h = 0, t = 0;

    q[t++] = root;

    while (h < t) {
        int count = t - h;

        while (count--) {
            N *n = q[h++];
            printf("%d(%c) ", n->v, n->c ? 'R' : 'B');

            if (n->k[0]) q[t++] = n->k[0];
            if (n->k[1]) q[t++] = n->k[1];
        }
        printf("\n");
    }
}

int main() {
    int n, v;
    char op[5];

    scanf("%d", &n);

    while (n--) {
        scanf("%s %d", op, &v);
        insert(v);
    }

    printLevelOrder();
    return 0;
}

//Experiment 2 Fractional Knapsack Problem
#include <stdio.h>

struct Item {
    int value;
    int weight;
    float ratio;
};

int main() {
    int n;
    float W;

    scanf("%d", &n);
    scanf("%f", &W);

    struct Item items[n];

    for (int i = 0; i < n; i++) {
        scanf("%d %d", &items[i].value, &items[i].weight);
        items[i].ratio = (float)items[i].value / items[i].weight;
    }

    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (items[i].ratio < items[j].ratio) {
                struct Item temp = items[i];
                items[i] = items[j];
                items[j] = temp;
            }
        }
    }

    float maxValue = 0.0;

    for (int i = 0; i < n && W > 0; i++) {
        if (items[i].weight <= W) {
            maxValue += items[i].value;
            W -= items[i].weight;
        } else {
            maxValue += items[i].ratio * W;
            W = 0;
        }
    }

    printf("%.2f\n", maxValue);

    return 0;
}

//Experiment No. 3 Job Sequencing with Deadlines
#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int id;
    int deadline;
    int profit;
} Job;

int compare(const void *a, const void *b) {
    Job *jobA = (Job *)a;
    Job *jobB = (Job *)b;
    return jobB->profit - jobA->profit;
}

int main() {
    int n;
    scanf("%d", &n);

    Job jobs[n];

    for (int i = 0; i < n; i++) {
        scanf("%d %d %d", &jobs[i].id, &jobs[i].deadline, &jobs[i].profit);
    }

    qsort(jobs, n, sizeof(Job), compare);

    int maxDeadline = 0;
    for (int i = 0; i < n; i++) {
        if (jobs[i].deadline > maxDeadline) {
            maxDeadline = jobs[i].deadline;
        }
    }

    int slot[maxDeadline];
    for (int i = 0; i < maxDeadline; i++) {
        slot[i] = -1;
    }

    int totalProfit = 0;

    for (int i = 0; i < n; i++) {
        for (int j = jobs[i].deadline - 1; j >= 0; j--) {
            if (slot[j] == -1) {
                slot[j] = jobs[i].id;
                totalProfit += jobs[i].profit;
                break;
            }
        }
    }

    printf("Scheduled tasks: ");
    for (int i = 0; i < maxDeadline; i++) {
        if (slot[i] != -1) {
            printf("%d ", slot[i]);
        }
    }

    printf("\nMaximum Profit: %d\n", totalProfit);

    return 0;
}

