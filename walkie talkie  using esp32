//EXP 6. Rabin–Karp string matching algorithm
#include <stdio.h>
#include <string.h>

#define d 256
#define q 101

void rabinKarp(char text[], char pattern[]){
    int n = strlen(text);
    int m = strlen(pattern);
    int i, j;
    int p = 0;
    int t = 0;
    int h = 1;
    int found = 0;

    /* Calculate h = (d^(m-1)) % q */
    for (i = 0; i < m - 1; i++){
        h = (h * d) % q;
    }

    /* Calculate initial hash values */
    for (i = 0; i < m; i++){
        p = (d * p + pattern[i]) % q;
        t = (d * t + text[i]) % q;
    }

    /* Slide the pattern over text */
    for (i = 0; i <= n - m; i++){

        if (p == t){
            for (j = 0; j < m; j++){
                if (text[i + j] != pattern[j]){
                    break;
                }
            }

            if (j == m){
                printf("Pattern found at index: %d\n", i);
                found = 1;
            }
        }

        if (i < n - m){
            t = (d * (t - text[i] * h) + text[i + m]) % q;

            if (t < 0){
                t = t + q;
            }
        }
    }

    if (found == 0){
        printf("Pattern not found\n");
    }
}

int main(){
    char text[1000];
    char pattern[100];

    scanf("%s", text);
    scanf("%s", pattern);

    rabinKarp(text, pattern);

    return 0;
}

// Exp  7 Longest Common Subsequence (LCS)
#include <stdio.h>
#include <string.h>

int main() {
    char X[1001], Y[1001];
    scanf("%s %s", X, Y);
    
    int m = strlen(X), n = strlen(Y);
    int dp[1001][1001];
    
    for (int i = 0; i <= m; i++) {
        for (int j = 0; j <= n; j++) {
            if (i == 0 || j == 0)
                dp[i][j] = 0;
            else if (X[i-1] == Y[j-1])
                dp[i][j] = dp[i-1][j-1] + 1;
            else
                dp[i][j] = dp[i-1][j] > dp[i][j-1] ? dp[i-1][j] : dp[i][j-1];
        }
    }
    
    int len = dp[m][n];
    char lcs[1001];
    int idx = len;
    lcs[idx] = '\0';
    
    int i = m, j = n;
    while (i > 0 && j > 0) {
        if (X[i-1] == Y[j-1]) {
            lcs[--idx] = X[i-1];
            i--; j--;
        } else if (dp[i-1][j] >= dp[i][j-1]) {  
            i--;
        } else {
            j--;
        }
    }
    
    printf("Length of LCS: %d\n", len);
    printf("LCS: %s\n", lcs);
    
    return 0;
}

//EXP 8 Computational Efficiency Analyzer
#include <stdio.h>

// Recursive approach
long long fibRecursive(int n) {
    if (n <= 1)
        return n;
    return fibRecursive(n - 1) + fibRecursive(n - 2);
}

// Non-recursive (Dynamic Programming / Iterative) approach
long long fibNonRecursive(int n) {
    if (n <= 1)
        return n;
    
    long long a = 0, b = 1, c;
    for (int i = 2; i <= n; i++) {
        c = a + b;
        a = b;
        b = c;
    }
    return b;
}

int main() {
    int n;
    scanf("%d", &n);
    
    printf("Recursive Fibonacci(%d): %lld\n", n, fibRecursive(n));
    printf("Non-Recursive Fibonacci(%d): %lld\n", n, fibNonRecursive(n));
    
    return 0;
}
